#!/bin/bash
# ai-brain: helper and maintenance utility for AI-Brains

   if [ "$*" == "-?" ]; then
      ec -g "   ai-brain: helper and maintenance utility for AI-Brains (version `ai-brain --version`)"
      echo '   usage: ai-brain --setup       # install hook into AI-Brain'
      echo '          ai-brain --cleanup     # remove hook'
      echo '          ai-brain --demo        # create example AI-Brain at ~/§Privat'
      echo '          ai-brain --context     # print masterspace context along cwd path'
      echo '          ai-brain --tutorial    # step-by-step setup walkthrough'
      echo '          ai-brain --help        # comprehensive help'
      echo '          ai-brain --version     # print version'
      echo '          ai-brain --check       # verify required dependencies are installed'
      echo '          ai-brain -!            # install ai-brain into a PATH directory'
      echo '   see also: chk, ec, pimp'
      exit 1
   fi

#===============================================================================
# comprehensive help: ai-brain --help
#===============================================================================

   if [ "$*" == "--help" ]; then
      echo '   ai-brain — central CLI for an AI-Brain'
      echo ''
      ec -g '   Concept:'
      echo '     An AI-Brain is a directory hierarchy whose root starts with'
      echo '     a §-prefix, where each node may carry an @-subfolder (the'
      echo '     masterspace). On every AI query the masterspaces along the'
      echo '     cwd path are activated as context.'
      echo ''
      ec -g '   Commands:'
      ec -y '     ai-brain --setup'
      echo '         Finds the AI-Brain root (the nearest § directory above'
      echo '         cwd) and places a .claude/settings.json there with a'
      echo '         UserPromptSubmit hook that invokes ai-brain --context. An'
      echo '         existing settings.json is overwritten.'
      echo ''
      ec -y '     ai-brain --cleanup'
      echo '         Removes the settings.json created by --setup. Masterspaces'
      echo '         and directory structure remain untouched.'
      echo ''
      ec -y '     ai-brain --demo'
      echo '         Creates the example AI-Brain at ~/§Privat — directory tree'
      echo '         plus seven pre-populated masterspace .md files covering'
      echo '         recipes (with dishes/drinks sub-branches) and electronics'
      echo '         development (power + RF sub-branches). Refuses to run if'
      echo '         ~/§Privat already exists.'
      echo ''
      ec -y '     ai-brain --context'
      echo '         Walks up from the current directory to the filesystem'
      echo '         root, collecting every @-subfolder along the way and'
      echo '         printing its .md contents as <skill src="…"> blocks on'
      echo '         stdout. Independent of Claude Code — the UserPromptSubmit'
      echo '         hook installed by --setup invokes this command on every'
      echo '         query.'
      echo ''
      ec -y '     ai-brain --tutorial'
      echo '         Prints a step-by-step setup walkthrough with copy-paste'
      echo '         ready bash blocks.'
      echo ''
      ec -y '     ai-brain --version'
      echo '         Prints the version number.'
      echo ''
      ec -y '     ai-brain --check'
      echo '         Verifies that all required dependencies (ec, jq, claude) and'
      echo '         optional ones (tree) are available on PATH; reports OK/FAIL'
      echo '         per item with a fix hint. Exit 0 if all required pass.'
      echo ''
      ec -g '   Conventions:'
      echo '     §<name>/        AI-Brain root'
      echo '     @/              masterspace (context files)'
      echo '     .claude/        configuration folder (settings.json)'
      echo ''
      echo '   see also: chk, ec'
      exit 1
   fi

#===============================================================================
# print version: ai-brain --version  (short form: --v)
#===============================================================================

   if [ "$*" == "--version" ] || [ "$*" == "--v" ]; then
      echo "1.3.4"; exit 0
   fi

#===============================================================================
# check dependencies: ai-brain --check
#===============================================================================

   if [ "$*" == "--check" ]; then
      if ! command -v ec >/dev/null 2>&1; then
         echo "checking ai-brain dependencies ..."
         echo "  FAIL: ec (color-echo helper, Bluccino toolchain) not found"
         echo "        => install from https://github.com/bluccino/tool-ec"
         echo "  (skipping further checks — ec is needed for coloured output)"
         exit 1
      fi
      ec -c "checking ai-brain dependencies ..."
      ERR=0

      # ec — already verified above
      ec -g "  OK:   ec (color-echo helper, Bluccino toolchain)"

      # jq — JSON manipulation, used by --setup and --cleanup
      if command -v jq >/dev/null 2>&1; then
         ec -g "  OK:   jq (JSON manipulator, used by --setup/--cleanup)"
      else
         ec -r "  FAIL: jq not found => brew install jq   or   apt install jq"
         ERR=1
      fi

      # claude — the Claude Code CLI that consumes the hook
      if command -v claude >/dev/null 2>&1; then
         ec -g "  OK:   claude (Claude Code CLI)"
      else
         ec -r "  FAIL: claude not found => https://docs.claude.com/en/docs/claude-code"
         ERR=1
      fi

      # tree — optional, used by the embedded tutorial for directory visualization
      if command -v tree >/dev/null 2>&1; then
         ec -g "  OK:   tree (optional, used by tutorial for directory visualization)"
      else
         ec -m "  WARN: tree not found (optional) => brew install tree   or   apt install tree"
      fi

      if [ "$ERR" != 0 ]; then
         ec -r "=> required dependencies missing"
         exit 1
      fi
      ec -g "=> all required dependencies installed"
      exit 0
   fi

#===============================================================================
# tutorial: ai-brain --tutorial  (step-by-step setup walkthrough)
#===============================================================================

   if [ "$*" == "--tutorial" ]; then
      ec -g 'AI-Brain — Step-by-Step Setup Tutorial'
      echo ''
      ec -c 'Step 1: Create the directory tree'
      echo ''
      cat <<'BLOCK'
mkdir -p \
  ~/§Privat/.claude \
  ~/§Privat/@ \
  ~/§Privat/Lieblingsrezepte/@ \
  ~/§Privat/Lieblingsrezepte/Lieblingsspeisen/@ \
  ~/§Privat/Lieblingsrezepte/Lieblingsgetränke/@ \
  ~/§Privat/Elektronikentwicklung/@ \
  ~/§Privat/Elektronikentwicklung/Leistungselektronik/@ \
  ~/§Privat/Elektronikentwicklung/HF-Elektronik/@
BLOCK
      echo ''
      ec -c 'Step 2: Inspect the directory tree'
      echo ''
      cat <<'BLOCK'
tree -a ~/§Privat
BLOCK
      echo ''
      ec -c 'Step 3: Fill the masterspaces'
      echo ''
      ec -c 'Root masterspace (applies to every query):'
      echo ''
      cat <<'BLOCK'
cat > ~/§Privat/@/persoenliche-allgemein.md <<'EOF'
# Persönliche allgemeine Präferenzen

- Sprache: Deutsch
- Anrede: Du
- Stil: knapp, sachlich, direkt
- Bei Code-Beispielen: kommentiere sparsam, nur wo es nicht-offensichtlich ist
EOF
BLOCK
      echo ''
      ec -c 'Recipes masterspace:'
      echo ''
      cat <<'BLOCK'
cat > ~/§Privat/Lieblingsrezepte/@/rezept-vorlieben.md <<'EOF'
# Rezept-Vorlieben

- Wenig Zucker, wenn möglich
- Bevorzugt mediterrane und alpenländische Küche
- Keine Erdnüsse (Allergie im Haushalt)
- Mengenangaben in Gramm und Esslöffeln, nicht in Cups
EOF
BLOCK
      echo ''
      ec -c 'Dishes subspace:'
      echo ''
      cat <<'BLOCK'
cat > ~/§Privat/Lieblingsrezepte/Lieblingsspeisen/@/speisen-praeferenzen.md <<'EOF'
# Speisen-Präferenzen

- Bevorzugte Garmethoden: Schmoren, Niedertemperatur, Backofen
- Lieblings-Aromen: Rosmarin, Thymian, Knoblauch, Zitrone
- Vegetarisch ist willkommen, muss aber nicht sein
EOF
BLOCK
      echo ''
      ec -c 'Step 4: Inspect the populated tree'
      echo ''
      cat <<'BLOCK'
tree -a ~/§Privat
BLOCK
      echo ''
      ec -c 'Step 5: Install the hook'
      echo ''
      cat <<'BLOCK'
ai-brain --setup
BLOCK
      echo ''
      ec -c 'Step 6: First probe query'
      echo ''
      cat <<'BLOCK'
cd ~/§Privat/Lieblingsrezepte/Lieblingsspeisen
claude
BLOCK
      echo ''
      echo 'Inside Claude, try a prompt such as:'
      echo '"Suggest an apple-strudel variation with less sugar."'
      echo ''
      ec -c 'Step 7: Verify'
      echo ''
      ec -c 'Direct context probe (shows what Claude would receive):'
      echo ''
      cat <<'BLOCK'
cd ~/§Privat/Lieblingsrezepte/Lieblingsspeisen
ai-brain --context
BLOCK
      echo ''
      ec -c 'Side-branch comparison (Elektronik instead of Rezepte):'
      echo ''
      cat <<'BLOCK'
cd ~/§Privat/Elektronikentwicklung/Leistungselektronik
ai-brain --context
BLOCK
      echo ''
      echo 'Different masterspaces should be activated.'
      echo ''
      ec -c 'Step 8 (optional): Remove the hook'
      echo ''
      cat <<'BLOCK'
ai-brain --cleanup
BLOCK
      echo ''
      exit 1
   fi

#===============================================================================
# install: ai-brain -!   (curl-installed scratch file copies itself to PATH dir)
#===============================================================================

   if [ "$*" == "-!" ]; then
      if [ ! -f ~ai-brain ]; then
         echo "error: ai-brain -!  needs file ~ai-brain in current directory" >&2
         echo "       (created by the curl install one-liner — see README)" >&2
         exit 1
      fi
      chmod +x ~ai-brain

      echo "select target directory for installation of ai-brain:"
      LIST=$(echo "$PATH" | tr ':' ' ')
      select DIR in $LIST
      do
         if [ "$DIR" == "" ]; then
            exit 0
         fi
         ERR="0"
         touch "$DIR/_junk_" 2>/dev/null || ERR="1"
         rm -f "$DIR/_junk_" 2>/dev/null

         ec -g "=== installing ai-brain in $DIR ..."
         if [ "$ERR" == "0" ]; then
            ec -y "  cp ~ai-brain $DIR/ai-brain"
            cp ~ai-brain "$DIR/ai-brain" || exit 1
         else
            ec -c "  this is a protected directory which uses a password!"
            ec -y "  sudo cp ~ai-brain $DIR/ai-brain"
            sudo cp ~ai-brain "$DIR/ai-brain" || exit 1
         fi
         ec -g "=== successful installation of ai-brain"
         echo "  => enter: ai-brain -?   # to see usage"

         rm -f ~ai-brain
         exit 0
      done
      exit 0
   fi

#===============================================================================
# setup hook: ai-brain --setup   (merges hook into ~/.claude/settings.json)
#===============================================================================

   if [ "$*" == "--setup" ]; then
      if ! command -v ai-brain >/dev/null 2>&1; then
         ec -r "ai-brain not found on PATH"
         ec -r "   install ai-brain into a PATH directory first (e.g. ai-brain -!)"
         exit 1
      fi
      HOOK_CMD="ai-brain --context"
      SETTINGS="$HOME/.claude/settings.json"

      ec -c "hook command:  $HOOK_CMD"
      ec -c "settings file: $SETTINGS"

      ec -y "=> ensuring $(dirname "$SETTINGS") exists"
      mkdir -p "$(dirname "$SETTINGS")" || exit 1

      INPUT=$(cat "$SETTINGS" 2>/dev/null || echo '{}')
      if ! printf '%s' "$INPUT" | jq empty 2>/dev/null; then
         ec -r "$SETTINGS exists but is not valid JSON. Aborting."
         exit 1
      fi

      ec -y "=> merging UserPromptSubmit hook into settings.json"
      NEW=$(printf '%s' "$INPUT" | jq --arg cmd "$HOOK_CMD" '
        .hooks //= {}
        | .hooks.UserPromptSubmit //= []
        | if any(.hooks.UserPromptSubmit[];
                 (.hooks // [])[]?.command
                 | ((. == $cmd) or endswith("/" + $cmd)))
          then .
          else .hooks.UserPromptSubmit += [{hooks: [{type: "command", command: $cmd}]}]
          end
      ') || exit 1

      TMP=$(mktemp)
      printf '%s\n' "$NEW" > "$TMP"
      mv "$TMP" "$SETTINGS" || exit 1

      ec -g "OK — hook installed in $SETTINGS"
      exit 0
   fi

#===============================================================================
# cleanup hook: ai-brain --cleanup   (removes hook from ~/.claude/settings.json)
#===============================================================================

   if [ "$*" == "--cleanup" ]; then
      HOOK_CMD="ai-brain --context"
      SETTINGS="$HOME/.claude/settings.json"

      ec -c "hook command:  $HOOK_CMD"
      ec -c "settings file: $SETTINGS"

      if [ ! -f "$SETTINGS" ]; then
         ec -m "no $SETTINGS to clean"
         exit 0
      fi

      INPUT=$(cat "$SETTINGS")
      if ! printf '%s' "$INPUT" | jq empty 2>/dev/null; then
         ec -r "$SETTINGS exists but is not valid JSON. Aborting."
         exit 1
      fi

      ec -y "=> removing UserPromptSubmit entries that invoke ai-brain --context"
      NEW=$(printf '%s' "$INPUT" | jq --arg cmd "$HOOK_CMD" '
        if .hooks.UserPromptSubmit then
          .hooks.UserPromptSubmit |= map(
            select((.hooks // [])
                   | any(.command | ((. == $cmd) or endswith("/" + $cmd)))
                   | not)
          )
          | if .hooks.UserPromptSubmit == [] then del(.hooks.UserPromptSubmit) else . end
          | if .hooks == {} then del(.hooks) else . end
        else . end
      ') || exit 1

      TMP=$(mktemp)
      printf '%s\n' "$NEW" > "$TMP"
      mv "$TMP" "$SETTINGS" || exit 1

      ec -g "OK — hook removed from $SETTINGS"
      exit 0
   fi

#===============================================================================
# demo: ai-brain --demo  (creates example AI-Brain at ~/§Privat)
#===============================================================================

   if [ "$*" == "--demo" ]; then
      if [ -d ~/§Privat ]; then
         ec -r "~/§Privat already exists — refusing to overwrite"
         ec -r "   delete it manually (rm -rf ~/§Privat) if you really want to re-create the demo"
         exit 1
      fi

      ec -y "=> creating directory tree under ~/§Privat"
      mkdir -p \
         ~/§Privat/@ \
         ~/§Privat/Lieblingsrezepte/@ \
         ~/§Privat/Lieblingsrezepte/Lieblingsspeisen/@ \
         ~/§Privat/Lieblingsrezepte/Lieblingsgetränke/@ \
         ~/§Privat/Elektronikentwicklung/@ \
         ~/§Privat/Elektronikentwicklung/Leistungselektronik/@ \
         ~/§Privat/Elektronikentwicklung/HF-Elektronik/@ || exit 1

      ec -y "=> writing root masterspace"
      cat > ~/§Privat/@/persoenliche-allgemein.md <<'EOF'
# Persönliche allgemeine Präferenzen

- Sprache: Deutsch
- Anrede: Du
- Stil: knapp, sachlich, direkt
- Bei Code-Beispielen: kommentiere sparsam, nur wo es nicht-offensichtlich ist
EOF

      ec -y "=> writing Lieblingsrezepte masterspaces"
      cat > ~/§Privat/Lieblingsrezepte/@/rezept-vorlieben.md <<'EOF'
# Rezept-Vorlieben

- Wenig Zucker, wenn möglich
- Bevorzugt mediterrane und alpenländische Küche
- Keine Erdnüsse (Allergie im Haushalt)
- Mengenangaben in Gramm und Esslöffeln, nicht in Cups
EOF

      cat > ~/§Privat/Lieblingsrezepte/Lieblingsspeisen/@/speisen-praeferenzen.md <<'EOF'
# Speisen-Präferenzen

- Bevorzugte Garmethoden: Schmoren, Niedertemperatur, Backofen
- Lieblings-Aromen: Rosmarin, Thymian, Knoblauch, Zitrone
- Vegetarisch ist willkommen, muss aber nicht sein
EOF

      cat > ~/§Privat/Lieblingsrezepte/Lieblingsgetränke/@/getraenke-vorlieben.md <<'EOF'
# Getränke-Präferenzen

- Bevorzugte Tees: Earl Grey, Sencha, Pfefferminze
- Lieblings-Cocktails: Old Fashioned, Negroni, Aperol Spritz
- Alkoholfrei: hausgemachte Sirupe (Holunder, Ingwer-Zitrone, Hibiskus)
- Kaffee: Espresso aus mittlerer Röstung, italienisch
- Wein: trockene Weiße aus Österreich (Grüner Veltliner), spritzige Rosés
EOF

      ec -y "=> writing Elektronikentwicklung masterspaces"
      cat > ~/§Privat/Elektronikentwicklung/@/bauteil-bestand.md <<'EOF'
# Bauteil-Bestand und Hersteller-Präferenzen

## Im Lager

- Mikrocontroller: STM32 (G0/F4-Serie), ESP32, RP2040
- Op-Amps: TL072, OPA2134, MCP6004
- Spannungsregler: LM317, LDOs MCP1700, AMS1117
- Passive: E12-Widerstandsserie 0805, MLCCs X7R bis 10 µF

## Bevorzugte Hersteller

- ICs: Texas Instruments, ST Microelectronics, Microchip
- Passive: Vishay, Murata, Kemet
- Steckverbinder: Phoenix Contact (Schraubklemmen), Molex (Pinheader)

## Distributoren

- Erstwahl Mouser, alternativ Digi-Key
- Lokal: RS Components Österreich
EOF

      cat > ~/§Privat/Elektronikentwicklung/Leistungselektronik/@/leistungsdesign-notizen.md <<'EOF'
# Leistungselektronik — Designnotizen

## Bewährte Topologien

- Buck-Converter: TPS62xxx-Familie für 12 V → 5 V / 3.3 V bis 1 A
- Linearer Vorregler vor empfindlicher Analogstufe (LDO mit niedrigem PSRR)
- Synchron-Buck bei > 1 A, asynchron darunter
- Ladungspumpen für 5 V → ±5 V symmetrisch (LM27761)

## Eigene Erfahrungen

- Layout: Stromschleifen so klein wie möglich, Switching-Node-Fläche minimieren
- Eingangs-Caps: mindestens 10 µF Keramik direkt am IC, 100 µF Bulk
- Snubber an MOSFET-Schaltern: RC-Glied dimensioniert nach Resonanz
- EMV: Ferrit-Bead in V_in bei längerer Zuleitung
EOF

      cat > ~/§Privat/Elektronikentwicklung/HF-Elektronik/@/hf-design-notizen.md <<'EOF'
# HF-Elektronik — Designnotizen

## Bevorzugte Topologien

- Antennen-Matching: Pi-Netzwerk für 50 Ω auf 2.4 GHz
- Bandpass: LC-Filter 3. Ordnung für Schmalband-Anwendungen
- Tiefpass am ADC-Eingang: RC + L für Anti-Aliasing
- Balun: integrierte Bauteile (Murata LFB-Serie) statt diskreter Übertrager

## EMV-Erfahrungen

- Massefläche durchgehend, möglichst ohne Schnitte unter HF-Bahnen
- Via-Stitching am Rand der GND-Fläche (Abstand λ/20)
- Schirmung: kleine Blech-Käppchen (Würth WE-SHC) statt Vollblechen
- ESD: TVS-Dioden möglichst nahe am Steckverbinder

## Messtechnik

- VNA: NanoVNA-V2 reicht für die meisten Hobby-Anpassungen bis 3 GHz
- Spektrum: TinySA für Voruntersuchungen, RSA für ernsthafte Messungen
EOF

      ec -g "OK — demo AI-Brain created at ~/§Privat (7 masterspaces populated)"
      ec -c "next step: ai-brain --setup   # register the hook so Claude Code uses the context"
      exit 0
   fi

#===============================================================================
# context dump: ai-brain --context  (collects masterspace .md files along cwd→/)
#===============================================================================

   if [ "$*" == "--context" ]; then
      D="$PWD"
      A=()
      while [ "$D" != "/" ]; do
         A=("$D" "${A[@]}")
         D="$(dirname "$D")"
      done
      for D in "${A[@]}"; do
         S="$D/@"
         if [ -d "$S" ]; then
            ec -g "=> processing $S" >&2
            find "$S" -name "*.md" | sort | while IFS= read -r f; do
               echo "<skill src=\"$f\">"
               cat "$f"
               echo "</skill>"
            done
         fi
      done
      exit 0
   fi

#===============================================================================
# no args: directory walk with masterspace listing
#   - cyan : project directories (those carrying an @/ masterspace)
#   - white: ancestor directories without @/
#   - green: .md filenames inside @/ directories
#===============================================================================

   if [ -z "$*" ]; then
      D="$PWD"
      A=()
      while [ "$D" != "/" ]; do
         A=("$D" "${A[@]}")
         D="$(dirname "$D")"
      done
      inside=0
      for D in "${A[@]}"; do
         # skip paths containing any dot-prefixed component (.claude, .pimp, .git, …)
         case "$D" in */.*) continue ;; esac
         # skip ancestors above the AI-Brain root (the first §-prefixed directory)
         if [ "$inside" -eq 0 ]; then
            case "$(basename "$D")" in
               §*) inside=1 ;;
               *)  continue ;;
            esac
         fi
         if [ -d "$D/@" ]; then
            ec -c "$D"
            find "$D/@" -name "*.md" | sort | while IFS= read -r f; do
               ec -g "   $(basename "$f")"
            done
         else
            ec "$D"
         fi
      done
      exit 0
   fi

#===============================================================================
# cannot deal with anything else ...
#===============================================================================

   ai-brain -?
   exit 1
